{
  "name": "@adminforth/markdown",
  "version": "1.0.0",
  "description": "Markdown plugin for adminforth",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://adminforth.dev/docs/tutorial/Plugins/markdown/",
  "scripts": {
    "build": "tsc && rsync -av --exclude 'node_modules' custom dist/"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "adminforth",
    "markdown"
  ],
  "author": "DevForth (https://devforth.io)",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.7",
    "adminforth": "^2.50.0",
    "semantic-release": "^24.2.1",
    "semantic-release-slack-bot": "^4.0.2",
    "typescript": "^5.7.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/devforth/adminforth-markdown.git"
  },
  "peerDependencies": {
    "adminforth": "^2.50.0"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "semantic-release-slack-bot",
        {
          "packageName": "@adminforth/markdown",
          "notifyOnSuccess": true,
          "notifyOnFail": true,
          "slackIcon": ":package:",
          "markdownReleaseNotes": true
        }
      ]
    ],
    "branches": [
      "main",
      {
        "name": "next",
        "prerelease": true
      }
    ]
  }
}
